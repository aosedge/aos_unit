set -Eeuo pipefail

LIBEXEC_DIR="$(dirname "$(realpath "$0")")"
readonly LIBEXEC_DIR
readonly LOG_TAG="aos-unit:network-helper"
. "${LIBEXEC_DIR}/log-helper"

: "${RUNTIME_DIRECTORY:?RUNTIME_DIRECTORY is undefined. Check systemd unit.}"
: "${NETWORK_CONFIG:?NETWORK_CONFIG is undefined. Check systemd unit.}"
: "${DHCP_HOSTS_DIR:?DHCP_HOSTS_DIR is undefined. Check systemd unit.}"
: "${DNS_HOSTS_DIR:?DNS_HOSTS_DIR is undefined. Check systemd unit.}"

: "${BRIDGE_NAME:?BRIDGE_NAME missing in $NETWORK_CONFIG}"
: "${BRIDGE_IP:?BRIDGE_IP missing in $NETWORK_CONFIG}"
: "${NETMASK:?NETMASK missing in $NETWORK_CONFIG}"
: "${DHCP_START:?DHCP_START missing in $NETWORK_CONFIG}"
: "${DHCP_END:?DHCP_END missing in $NETWORK_CONFIG}"

readonly NET_LOCK="${RUNTIME_DIRECTORY}/net.lock"

readonly TABLE_FAMILY="inet"
readonly TABLE_NAME="aos_unit"
readonly POSTROUTING_CHAIN="postrouting"
readonly FORWARD_CHAIN="forward"

readonly DHCP_HOSTS_FILE="${RUNTIME_DIRECTORY}/${DHCP_HOSTS_DIR}/hosts"
readonly DNS_HOSTS_FILE="${RUNTIME_DIRECTORY}/${DNS_HOSTS_DIR}/hosts"

readonly ROUTEMONITOR_UNIT="aos-unit-route-monitor"

readonly DNS_ALT_PORT="${DNS_ALT_PORT:-5300}"
readonly UPSTREAM_DNS="${UPSTREAM_DNS:-127.0.0.53}"

readonly DNSMASQ_UNIT="aos-unit-dnsmasq"

readonly DHCP_LEASE_TIME="12h"

readonly WAIT_INTERVAL=0.2

lock() {
    exec 9>"$NET_LOCK"
    flock -x 9
}

wait_for_transient_cleanup() {
    local -r unit_name="$1"

    trap 'die "${EXIT_RUNTIME_ERROR}" "CRITICAL ERROR: Systemd timeout reached! ${unit_name} failed to clean up."' SIGTERM
    while [[ "$(systemctl show -p LoadState --value "${unit_name}.service" 2>/dev/null)" != "not-found" ]]; do
        sleep "${WAIT_INTERVAL}"
    done
    trap - SIGTERM
}

table_present() {
    nft list table "$TABLE_FAMILY" "$TABLE_NAME" >/dev/null 2>&1
}

detect_internet_interface() {
    ip route show default 0.0.0.0/0 2>/dev/null | awk 'NR==1 {print $5}'
}

resolve_internet_interface() {
    local iface="${INTERNET_INTERFACE:-}"

    if [[ -n $iface ]]; then
        if [[ -e "/sys/class/net/$iface" ]]; then
            printf '%s\n' "$iface"
        else
            die "${EXIT_CONFIG_ERROR}" "Explicit INTERNET_INTERFACE '$iface' not found in /sys/class/net/"
        fi
    else
        detect_internet_interface
    fi
}

add_nat() {
    local uplink
    uplink="$(resolve_internet_interface || true)"
    if [[ -z ${uplink:-} ]]; then
        log "No default route yet; skipping NAT setup"
        exit 0
    fi

    lock

    if ! table_present; then
        die "${EXIT_RUNTIME_ERROR}" "nft table ${TABLE_FAMILY} ${TABLE_NAME} not present"
    fi

    if [[ "$(systemctl show -p ActiveState --value "${ROUTEMONITOR_UNIT}.service" 2>/dev/null)" == "active" ]]; then
        die "${EXIT_RUNTIME_ERROR}" "${ROUTEMONITOR_UNIT} service is already running"
    fi

    log "Configuring NAT: bridge=$BRIDGE_NAME uplink=$uplink"

    if ! nft -f - <<EOF; then
flush chain $TABLE_FAMILY $TABLE_NAME $POSTROUTING_CHAIN
flush chain $TABLE_FAMILY $TABLE_NAME $FORWARD_CHAIN
add rule $TABLE_FAMILY $TABLE_NAME $FORWARD_CHAIN ct state established,related accept
add rule $TABLE_FAMILY $TABLE_NAME $FORWARD_CHAIN iifname "$BRIDGE_NAME" oifname "$uplink" accept
add rule $TABLE_FAMILY $TABLE_NAME $POSTROUTING_CHAIN oifname "$uplink" masquerade
EOF
        die "${EXIT_RUNTIME_ERROR}" "Failed to apply nft NAT rules"
    fi

    # Spawn monitor only if not already running and no static interface forced
    if [[ -z ${INTERNET_INTERFACE:-} ]]; then
        log "Starting dynamic route monitoring unit: ${ROUTEMONITOR_UNIT}"
        systemd-run \
            --unit="${ROUTEMONITOR_UNIT}" \
            --description="AosEdge Route Monitor (Uplink: ${uplink:-None})" \
            --property="EnvironmentFile=${RUNTIME_DIRECTORY}/${NETWORK_CONFIG}" \
            --setenv="RUNTIME_DIRECTORY=${RUNTIME_DIRECTORY}" \
            --setenv="NETWORK_CONFIG=${NETWORK_CONFIG}" \
            --setenv="DHCP_HOSTS_DIR=${DHCP_HOSTS_DIR}" \
            --setenv="DNS_HOSTS_DIR=${DNS_HOSTS_DIR}" \
            --property="Type=simple" \
            --property="BindsTo=aos-unit.service" \
            --property="User=aos-unit" \
            --property="Group=aos-unit" \
            --property="AmbientCapabilities=CAP_NET_ADMIN" \
            --property="CapabilityBoundingSet=CAP_NET_ADMIN" \
            --property="RestrictAddressFamilies=AF_UNIX AF_NETLINK AF_INET AF_INET6" \
            --property="Restart=on-failure" \
            --property="RestartSec=1s" \
            --property="KillMode=control-group" \
            --property="KillSignal=SIGTERM" \
            --property="TimeoutStopSec=5s" \
            --property="SendSIGKILL=yes" \
            --property="NoNewPrivileges=yes" \
            --property="PrivateTmp=yes" \
            --property="ProtectSystem=strict" \
            --property="ProtectHome=yes" \
            --property="ProtectKernelTunables=yes" \
            --property="ProtectKernelModules=yes" \
            --property="ProtectControlGroups=yes" \
            --property="ProtectKernelLogs=yes" \
            --property="PrivateDevices=yes" \
            --property="LockPersonality=yes" \
            --property="MemoryDenyWriteExecute=yes" \
            --property="RestrictNamespaces=yes" \
            --property="RestrictRealtime=yes" \
            --property="SystemCallArchitectures=native" \
            --property="ReadWritePaths=${RUNTIME_DIRECTORY}" \
            --collect \
            --quiet -- \
            "${LIBEXEC_DIR}/route-monitor"
    fi
}

del_nat() {
    lock

    if ! table_present; then
        log "nft table not present; nothing to remove"
        exit 0
    fi

    log "Removing NAT rules"

    nft -f - <<EOF
flush chain $TABLE_FAMILY $TABLE_NAME $POSTROUTING_CHAIN
flush chain $TABLE_FAMILY $TABLE_NAME $FORWARD_CHAIN
add rule $TABLE_FAMILY $TABLE_NAME $FORWARD_CHAIN ct state established,related accept
EOF
}

update_hosts_add() {
    local ip_addr="$1"
    local host="$2"
    local fqdn="${host}.aos-unit"
    local tmp="${DNS_HOSTS_FILE}~"

    awk -v ip="$ip_addr" -v h="$host" -v f="$fqdn" '
    {
        for (i = 2; i <= NF; i++) {
            if ($i == f || $i == h) next
        }
        print $0
    }
    END {
        print ip " " f " " h
    }
    ' "$DNS_HOSTS_FILE" >"$tmp" && mv "$tmp" "$DNS_HOSTS_FILE"
}

update_hosts_del() {
    local host="$1"
    local fqdn="${host}.aos-unit"
    local tmp="${DNS_HOSTS_FILE}~"

    awk -v h="$host" -v f="$fqdn" '
    {
        for (i = 2; i <= NF; i++) {
            if ($i == f || $i == h) next
        }
        print $0
    }
    ' "$DNS_HOSTS_FILE" >"$tmp" && mv "$tmp" "$DNS_HOSTS_FILE"
}

validate_host_name() {
    local host="${1:-}"

    if [[ -z $host || ${#host} -gt 63 ]]; then
        die "${EXIT_CONFIG_ERROR}" "Invalid hostname: '$host'"
    fi

    if ! [[ $host =~ ^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?$ ]]; then
        die "${EXIT_CONFIG_ERROR}" "Invalid hostname: '$host' (must be DNS label, no dots)"
    fi
}

validate_mac_addr() {
    local mac="${1:-}"

    local mac_lc
    mac_lc=$(printf '%s' "$mac" | tr 'A-F' 'a-f')

    if ! [[ $mac_lc =~ ^([0-9a-f]{2}:){5}[0-9a-f]{2}$ ]]; then
        die "${EXIT_CONFIG_ERROR}" "Invalid MAC address: '$mac' (expected format aa:bb:cc:dd:ee:ff)"
    fi

    printf '%s' "$mac_lc"
}

validate_ipv4_addr() {
    local ip="${1:-}"

    if ! awk -v ip="$ip" 'BEGIN {
        n = split(ip, octets, ".");
        if (n != 4) exit 1;

        for (i = 1; i <= 4; i++) {
            o = octets[i];
            if (o !~ /^[0-9]+$/) exit 1;
            if (length(o) > 3) exit 1;
            if (o ~ /^0[0-9]/) exit 1;
            if (o + 0 < 0 || o + 0 > 255) exit 1;
        }
        exit 0;
    }'; then
        die "${EXIT_CONFIG_ERROR}" "Invalid IP address: '$ip'"
    fi
}

add_tap() {
    local tap="${1:?tap required}"

    # Safety: interface name length (Linux IFNAMSIZ is 16, so 15 usable chars)
    if ((${#tap} > 15)); then
        die "${EXIT_CONFIG_ERROR}" "Error: tap name too long (>15): $tap"
    fi

    # Ensure bridge exists
    if ! ip link show dev "$BRIDGE_NAME" >/dev/null 2>&1; then
        die "${EXIT_CONFIG_ERROR}" "Error: bridge does not exist: $BRIDGE_NAME"
    fi

    # If tap exists, ensure it's a tuntap/tap (avoid clobbering host interfaces)
    if ip link show dev "$tap" >/dev/null 2>&1; then
        if ! ip -d link show dev "$tap" 2>/dev/null | grep -qE '\b(tun|tap)\b'; then
            die "${EXIT_CONFIG_ERROR}" "Error: interface exists but does not look like a tap/tun: $tap"
        fi
    else
        # Create tap owned by aos-unit
        ip tuntap add dev "$tap" mode tap user aos-unit group aos-unit ||
            die "${EXIT_CONFIG_ERROR}" "Error: failed to create tap interface: $tap"
    fi

    # Bring up and attach to bridge (idempotent)
    ip link set dev "$tap" up
    ip link set dev "$tap" master "$BRIDGE_NAME"
}

del_tap() {
    local tap="${1:?tap required}"

    if ((${#tap} > 15)); then
        die "${EXIT_CONFIG_ERROR}" "Error: tap name too long (>15): $tap"
    fi

    if ! ip link show dev "$tap" >/dev/null 2>&1; then
        return 0
    fi

    if ! ip -d link show dev "$tap" 2>/dev/null | grep -qE '\b(tun|tap)\b'; then
        die "${EXIT_CONFIG_ERROR}" "Error: refusing to delete non-tap interface: $tap"
    fi

    # Delete tap; kernel automatically handles detaching from the bridge
    ip link del dev "$tap" 2>/dev/null || true
}

add_vm() {
    local mac="${1:?mac required}"
    local host="${2:?hostname required}"
    local tap="${3:?tap required}"
    local ip="${4:-}"

    validate_host_name "$host"

    if [[ -n $ip ]]; then
        validate_ipv4_addr "$ip"
    fi

    lock

    local mac_lc
    mac_lc=$(validate_mac_addr "$mac")

    add_tap "${tap}"

    local tmp="${DHCP_HOSTS_FILE}~"

    log "Register VM: mac=$mac_lc host=$host${ip:+ ip=$ip}"

    awk -v m="$mac_lc" -v h="$host" -v ip="$ip" '
    BEGIN { IGNORECASE=1; wrote=0 }
    function newline() {
        if (ip!="") return m "," ip "," h
        else        return m "," h
    }
    /^[[:space:]]*[0-9a-fA-F]{2}:[0-9a-fA-F]{2}:/ {
        split($0, a, ",")
        mac=a[1]; hn=a[3]
        if (hn=="") hn=a[2]
        gsub(/[ \t\r\n]+/,"",mac); gsub(/[ \t\r\n]+/,"",hn)

        if (tolower(mac)==m || hn==h) {
            print newline()
            wrote=1
            next
        }
    }
    { print $0 }
    END { if (!wrote) print newline() }
    ' "$DHCP_HOSTS_FILE" >"$tmp" && mv "$tmp" "$DHCP_HOSTS_FILE"

    if [[ -n $ip ]]; then
        update_hosts_add "$ip" "${host}"
    fi
}

del_vm() {
    local mac="${1:?mac required}"
    local host="${2:?hostname required}"
    local tap="${3:?tap required}"
    local ip="${4:-}"

    validate_host_name "$host"

    local mac_lc
    mac_lc=$(validate_mac_addr "$mac")

    if [[ -n $ip ]]; then
        validate_ipv4_addr "$ip"
    fi

    lock

    del_tap "${tap}"

    if [[ ! -f $DHCP_HOSTS_FILE ]]; then
        log "VM registry missing; nothing to remove"
        exit 0
    fi

    log "Unregister VM: mac=$mac_lc host=$host${ip:+ ip=$ip}"

    local tmp="${DHCP_HOSTS_FILE}~"
    awk -v m="$mac_lc" '
    BEGIN { IGNORECASE=1 }
    /^[[:space:]]*[0-9a-fA-F]{2}:[0-9a-fA-F]{2}:/ {
        split($0, a, ",")
        mac=a[1]
        gsub(/[ \t\r\n]+/,"",mac)
        if (tolower(mac)==m) next
    }
    { print $0 }
    ' "$DHCP_HOSTS_FILE" >"$tmp" && mv "$tmp" "$DHCP_HOSTS_FILE"

    update_hosts_del "${host}"
}

lookup_vm_record() {
    local want_mac="$1"

    awk -v m="$want_mac" '
    BEGIN { IGNORECASE=1 }
    /^[[:space:]]*[0-9a-fA-F]{2}:[0-9a-fA-F]{2}:/ {
        split($0, a, ",")
        mac=a[1]
        gsub(/[ \t\r\n]+/,"",mac)
        if (tolower(mac) != m) next

        ip=a[2]
        host=a[3]
        if (host == "") { host=ip; ip="" }

        gsub(/[ \t\r\n]+/,"",ip)
        gsub(/[ \t\r\n]+/,"",host)

        print ip "|" host
        exit 0
    }
    ' "$DHCP_HOSTS_FILE" 2>/dev/null || true
}

lease_event() {
    local action="$1"
    local mac="$2"
    local ip="$3"
    local host_hint="$4" # Note: dnsmasq might send its own hostname idea here

    local mac_lc
    mac_lc=$(validate_mac_addr "$mac")

    lock

    local record
    record="$(lookup_vm_record "$mac_lc")"
    if [[ -z $record ]]; then
        log "Lease event ignored (MAC not whitelisted): mac=${mac_lc} action=${action}"
        exit 0
    fi

    local conf_ip="${record%%|*}"
    local conf_host="${record#*|}"

    validate_host_name "$conf_host"

    case "$action" in
        add | old)
            if [[ -n $conf_ip ]]; then
                log "Lease ${action}: using static mapping from vms.conf: ${conf_host} -> ${conf_ip}"
                update_hosts_add "$conf_ip" "$conf_host"
            else
                if [[ -z $ip || $ip == "*" ]]; then
                    log "Lease ${action}: missing IP from dnsmasq for ${conf_host}; skipping"
                    exit 0
                fi
                validate_ipv4_addr "$ip"
                log "Lease ${action}: learned mapping: ${conf_host} -> ${ip}"
                update_hosts_add "$ip" "$conf_host"
            fi
            ;;

        del)
            log "Lease del: removing mapping for ${conf_host}"
            update_hosts_del "$conf_host"
            ;;

        *)
            log "Unknown lease action '${action}' for mac=${mac_lc}; ignored"
            ;;
    esac
}

create_bridge() {
    if ip link show "$BRIDGE_NAME" &>/dev/null; then
        die "${EXIT_RUNTIME_ERROR}" "Bridge '$BRIDGE_NAME' already exists; aos-unit requires exclusive ownership."
    fi

    log "Creating bridge: $BRIDGE_NAME ($BRIDGE_IP)"
    ip link add "$BRIDGE_NAME" type bridge
    ip addr add "$BRIDGE_IP/$NETMASK" dev "$BRIDGE_NAME"
    ip link set "$BRIDGE_NAME" up
}

apply_nft_skeleton() {
    local -r ruleset="$RUNTIME_DIRECTORY/firewall-skeleton.nft"

    local dns_redirect_rules=""
    local dns_output_redirect_rules=""
    if [[ $DNS_ALT_PORT != "53" ]]; then
        dns_redirect_rules=$(
            cat <<EOF
        iifname "${BRIDGE_NAME}" udp dport 53 dnat to :${DNS_ALT_PORT}
        iifname "${BRIDGE_NAME}" tcp dport 53 dnat to :${DNS_ALT_PORT}
EOF
        )
        dns_output_redirect_rules=$(
            cat <<EOF
        ip daddr ${BRIDGE_IP} udp dport 53 dnat to ${BRIDGE_IP}:${DNS_ALT_PORT}
        ip daddr ${BRIDGE_IP} tcp dport 53 dnat to ${BRIDGE_IP}:${DNS_ALT_PORT}
EOF
        )
    fi

    nft delete table inet aos_unit 2>/dev/null || true

    cat >"$ruleset" <<EOF
#!/usr/sbin/nft -f

table inet aos_unit {

    chain prerouting {
        type nat hook prerouting priority -100; policy accept;
${dns_redirect_rules}
    }

    chain output {
        type nat hook output priority -100; policy accept;
${dns_output_redirect_rules}
    }

    chain postrouting {
        type nat hook postrouting priority 100; policy accept;
        # NAT masquerade rule is managed by network-helper add-nat/del-nat
    }

    chain forward {
        type filter hook forward priority 0; policy accept;
        ct state established,related accept
        # Forward allow rule is managed by network-helper add-nat/del-nat
    }
}
EOF

    nft -c -f "$ruleset"
    nft -f "$ruleset"
    log "nft skeleton applied (table inet aos_unit)"
}

configure_and_start_dnsmasq() {
    local -r conf_file="$RUNTIME_DIRECTORY/dnsmasq.conf"
    local -r leases_file="$RUNTIME_DIRECTORY/dnsmasq.leases"

    if [[ "$(systemctl show -p ActiveState --value "${DNSMASQ_UNIT}.service" 2>/dev/null)" == "active" ]]; then
        die "${EXIT_RUNTIME_ERROR}" "${DNSMASQ_UNIT} service is already running"
    fi

    mkdir -p "${RUNTIME_DIRECTORY}/${DHCP_HOSTS_DIR}" "${RUNTIME_DIRECTORY}/${DNS_HOSTS_DIR}"
    touch "$DNS_HOSTS_FILE"
    touch "$DHCP_HOSTS_FILE"

    cat >"$conf_file" <<EOF
# aos-unit dnsmasq
interface=${BRIDGE_NAME}
bind-interfaces
except-interface=lo

# DNS on bridge IP
port=${DNS_ALT_PORT}
listen-address=${BRIDGE_IP}
domain=aos-unit
local=/aos-unit/
expand-hosts

no-resolv
no-hosts
server=${UPSTREAM_DNS}

dhcp-script=${LIBEXEC_DIR}/dnsmasq-lease-hook

# DHCP
dhcp-range=${DHCP_START},${DHCP_END},${DHCP_LEASE_TIME}
dhcp-option=3,${BRIDGE_IP}
dhcp-option=6,${BRIDGE_IP}
dhcp-leasefile=${leases_file}
dhcp-ignore-clid
dhcp-ignore-names

# VM hostnames + DHCP hosts
hostsdir=${RUNTIME_DIRECTORY}/${DNS_HOSTS_DIR}
dhcp-hostsdir=${RUNTIME_DIRECTORY}/${DHCP_HOSTS_DIR}
EOF

    local dns_test_out
    dns_test_out=$(/usr/sbin/dnsmasq --test --conf-file="$conf_file" 2>&1) || {
        error_multi <<<"$dns_test_out"
        die "${EXIT_RUNTIME_ERROR}" "dnsmasq config test failed"
    }

    log "Starting dnsmasq as transient unit: ${DNSMASQ_UNIT}"
    systemd-run \
        --unit="$DNSMASQ_UNIT" \
        --description="AosEdge dnsmasq @${BRIDGE_IP}" \
        --property="EnvironmentFile=${RUNTIME_DIRECTORY}/${NETWORK_CONFIG}" \
        --setenv="RUNTIME_DIRECTORY=${RUNTIME_DIRECTORY}" \
        --setenv="NETWORK_CONFIG=${NETWORK_CONFIG}" \
        --setenv="DHCP_HOSTS_DIR=${DHCP_HOSTS_DIR}" \
        --setenv="DNS_HOSTS_DIR=${DNS_HOSTS_DIR}" \
        --property="Type=simple" \
        --property="BindsTo=aos-unit.service" \
        --property="PartOf=aos-unit.service" \
        --property="User=aos-unit" \
        --property="Group=aos-unit" \
        --property="AmbientCapabilities=CAP_NET_BIND_SERVICE CAP_NET_ADMIN CAP_NET_RAW" \
        --property="CapabilityBoundingSet=CAP_NET_BIND_SERVICE CAP_NET_ADMIN CAP_NET_RAW" \
        --property="RestrictAddressFamilies=AF_UNIX AF_NETLINK AF_INET AF_INET6" \
        --property="Restart=on-failure" \
        --property="RestartSec=1s" \
        --property="KillMode=control-group" \
        --property="KillSignal=SIGTERM" \
        --property="TimeoutStopSec=5s" \
        --property="SendSIGKILL=yes" \
        --property="NoNewPrivileges=yes" \
        --property="PrivateTmp=yes" \
        --property="ProtectSystem=strict" \
        --property="ProtectHome=yes" \
        --property="ProtectKernelTunables=yes" \
        --property="ProtectKernelModules=yes" \
        --property="ProtectControlGroups=yes" \
        --property="ProtectKernelLogs=yes" \
        --property="PrivateDevices=yes" \
        --property="LockPersonality=yes" \
        --property="MemoryDenyWriteExecute=yes" \
        --property="RestrictNamespaces=yes" \
        --property="RestrictRealtime=yes" \
        --property="SystemCallArchitectures=native" \
        --property="ReadWritePaths=${RUNTIME_DIRECTORY}" \
        --collect \
        --quiet -- \
        /usr/sbin/dnsmasq --keep-in-foreground --conf-file="$conf_file"

    if ! systemctl is-active --quiet "${DNSMASQ_UNIT}.service" 2>/dev/null; then
        systemctl --no-pager -l status "${DNSMASQ_UNIT}.service" 2>&1 | error_multi || true
        die "${EXIT_RUNTIME_ERROR}" "dnsmasq transient unit failed to start: ${DNSMASQ_UNIT}"
    fi
}

configure_resolved_routing() {
    if ! command -v resolvectl >/dev/null 2>&1; then
        die "${EXIT_RUNTIME_ERROR}" "resolvectl not found; host DNS routing for *.aos-unit is required"
    fi

    log "Configuring systemd-resolved routing: ~aos-unit via ${BRIDGE_IP} on ${BRIDGE_NAME}"

    if ! resolvectl dns "$BRIDGE_NAME" "$BRIDGE_IP"; then
        die "${EXIT_RUNTIME_ERROR}" "Failed to configure systemd-resolved DNS on ${BRIDGE_NAME} (polkit rule required)"
    fi

    if ! resolvectl domain "$BRIDGE_NAME" "~aos-unit"; then
        die "${EXIT_RUNTIME_ERROR}" "Failed to configure systemd-resolved domain routing on ${BRIDGE_NAME} (polkit rule required)"
    fi

    if ! resolvectl dnssec "$BRIDGE_NAME" no; then
        die "${EXIT_RUNTIME_ERROR}" "Failed to disable DNSSEC on ${BRIDGE_NAME}"
    fi

    if ! resolvectl dnsovertls "$BRIDGE_NAME" no; then
        die "${EXIT_RUNTIME_ERROR}" "Failed to disable DoT on ${BRIDGE_NAME}"
    fi
}

revert_resolved() {
    if command -v resolvectl >/dev/null 2>&1; then
        log "Reverting systemd-resolved settings for ${BRIDGE_NAME}"
        resolvectl revert "$BRIDGE_NAME" 2>/dev/null || true
    fi
}

remove_nft_table() {
    nft delete table inet aos_unit 2>/dev/null || true
    log "nft table inet aos_unit removed"
}

remove_bridge() {
    log "Removing bridge: $BRIDGE_NAME"
    ip link set "$BRIDGE_NAME" down 2>/dev/null || true
    ip link delete "$BRIDGE_NAME" type bridge 2>/dev/null || ip link delete "$BRIDGE_NAME" 2>/dev/null || true
}

do_startup() {
    create_bridge
    apply_nft_skeleton
    configure_and_start_dnsmasq
    configure_resolved_routing
    add_nat

    log "Startup complete"
}

do_cleanup() {
    wait_for_transient_cleanup ${ROUTEMONITOR_UNIT}"
    wait_for_transient_cleanup ${DNSMASQ_UNIT}"

    del_nat
    revert_resolved
    remove_nft_table
    remove_bridge

    log "Cleanup complete"
}

main() {
    local cmd="${1:-}"
    shift || true
    case "$cmd" in
        add-vm) add_vm "$@" ;;
        del-vm) del_vm "$@" ;;
        lease-event) lease_event "$@" ;;
        startup) do_startup ;;
        cleanup) do_cleanup ;;
        *) die "${EXIT_CONFIG_ERROR}" "Unknown command: $cmd" ;;
    esac
}

main "$@"
